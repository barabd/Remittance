# Production Deployment Configuration
# Copy this to .env.prod and fill in your production values
# NEVER commit real secrets — use CI/CD secrets management (GitHub Actions, GitLab CI, Azure Pipelines, etc.)

# ============ FRONTEND (Vite React) ============
# These are baked into the build, so use docker-compose or CI/CD
VITE_USE_LIVE_API=true
VITE_API_BASE_PATH=/api/v1
VITE_API_PROXY_TARGET=http://backend:4000

# Operations hub (optional email/push integration)
# VITE_OPS_EMAIL_SEND_API_URL=/api/v1/operations/delivery/email
# VITE_OPS_PUSH_SEND_API_URL=/api/v1/operations/delivery/push

# ============ BACKEND (Spring Boot) ============
# Database
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd

# SMTP (optional: real email send)
MAIL_ENABLED=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<your-sendgrid-api-key>
MAIL_FROM=ops@yourdomain.com

# FCM (optional: Firebase Cloud Messaging for push)
FCM_ENABLED=false
FCM_CREDENTIALS_PATH=/run/secrets/firebase-credentials.json
FCM_TOPIC=ops-alerts

# Spring Boot (via docker-compose env)
# SPRING_PROFILES_ACTIVE=prod

# ============ DOCKER DEPLOYMENT ============
# Usage:
#   docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Notes:
# - Requires Docker & docker-compose installed
# - Database will initialize from DDL scripts in database/mssql/
# - All services restart automatically if they crash
# - Use `docker-compose logs -f backend` to monitor the backend
#
# HTTPS/SSL:
# - Place your certificates in deploy/ssl/ (cert.pem, key.pem)
# - Uncomment the nginx config mount in docker-compose.prod.yml
# - Update docs/deploy/nginx.prod.conf with SSL directives
#
# Secrets management:
# - Use docker secrets (e.g., `docker secret create db_password <(echo 'secret')`)
# - Or use orchestration secrets (Kubernetes, AWS ECS, etc.)
# - NEVER embed secrets in docker-compose.prod.yml

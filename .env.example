# Set to true when a real backend implements docs/API_CONTRACT.md.
# Wired today: masters (beneficiaries/agents/cover + audits), AML alerts + POST /compliance/screen, MLA settings,
# investigation cases, bulk hub, operations hub (notifications / outbox / feedback), GET /metrics/dashboard,
# settlement/regulatory, remittance queue + tracking + single-entry IDs, disbursements + audit,
# exchange-house blocked remittances (eh_blocked_remittance ↔ Stopped status).
# When true, repositories call Java (server/frms-ops-api, port 4000) and merge responses into browser localStorage.
# See docs/STACK_INTEGRATION.md for DB apply order, merge checklist, and DDL ↔ Java ↔ REST ↔ UI map.
VITE_USE_LIVE_API=false

# Browser calls same-origin /api/v1; Vite proxies to VITE_API_PROXY_TARGET in dev.
VITE_API_BASE_PATH=/api/v1

# Dev-only: where `npm run dev` proxies /api/v1 (your API server).
VITE_API_PROXY_TARGET=http://127.0.0.1:4000

# When VITE_USE_LIVE_API=true, the app expects JWT login (sessionStorage) unless you disable it here:
# VITE_REQUIRE_LOGIN=false
#
# Optional: attach to every apiRequest (dev/staging only — never commit real secrets).
# VITE_API_BEARER_TOKEN=

# fetch() credentials: omit | same-origin | include (use include only with cookie-based API auth + server CSRF strategy).
# VITE_API_FETCH_CREDENTIALS=omit

# Operations hub — production email / push (optional). Browser POSTs JSON to these URLs (Bearer via VITE_API_BEARER_TOKEN).
# With frms-ops-api + Vite proxy, use same-origin paths:
# VITE_OPS_EMAIL_SEND_API_URL=/api/v1/operations/delivery/email
# VITE_OPS_PUSH_SEND_API_URL=/api/v1/operations/delivery/push
# Or external workers:
# VITE_OPS_EMAIL_SEND_API_URL=https://api.example.com/v1/ops/email/send
# VITE_OPS_PUSH_SEND_API_URL=https://api.example.com/v1/ops/push/alert

# MSSQL DDL index (SQL ↔ Java packages ↔ React: bulkHubStore, caseStore, operationsHub, …): database/mssql/README.md
#
# --- Java frms-ops-api (NOT read by Vite; set in shell or IDE when running Spring Boot) ---
# JWT auth (see server/frms-ops-api application.yml): set a strong FRMS_JWT_SECRET in production.
# FRMS_SECURITY_ENABLED=true
# FRMS_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# FRMS_JWT_EXPIRATION_MS=86400000
#
# FRMS_JDBC_URL=jdbc:sqlserver://localhost:1433;databaseName=frms_ops;encrypt=false;trustServerCertificate=true
# FRMS_DB_USER=sa
# FRMS_DB_PASSWORD=YourStrong!Passw0rd
#
# Real SMTP + FCM in Java (optional):
# FRMS_OPS_MAIL_ENABLED=true
# FRMS_SMTP_HOST=smtp.sendgrid.net
# FRMS_SMTP_PORT=587
# FRMS_SMTP_USER=apikey
# FRMS_SMTP_PASSWORD=<sendgrid-api-key>
# FRMS_MAIL_FROM=ops@yourdomain.com
#
# FRMS_OPS_FCM_ENABLED=true
# FRMS_FCM_CREDENTIALS_PATH=C:/secrets/firebase-service-account.json
# FRMS_FCM_TOPIC=ops-alerts
